{
  "enabled": true,
  "autoPauseFullscreen": true,

  "_comment_excludedApps": "Процессы, в которых утилита НЕ работает (RDP, VM, удалённый доступ). Сюда же можно добавить свои игры из лаунчеров, которые по какой-то причине не детектятся как fullscreen. Редактировать из трея: 'Disable in current app'.",
  "excludedApps": [
    "mstsc.exe",
    "parsec.exe",
    "moonlight.exe",
    "anydesk.exe",
    "teamviewer.exe",
    "vncviewer.exe",
    "vmware.exe",
    "virtualbox.exe",
    "virtualboxvm.exe",
    "prl_client_app.exe"
  ],

  "_comment_fullscreenWhitelist": "Процессы, в которых хоткеи работают ДАЖЕ в fullscreen. Браузеры (YouTube в F11), видеоплееры, IDE в zen-mode. Добавить текущий процесс — через трей.",
  "fullscreenWhitelist": [
    "chrome.exe",
    "msedge.exe",
    "firefox.exe",
    "brave.exe",
    "opera.exe",
    "vivaldi.exe",
    "arc.exe",
    "yandex.exe",
    "browser.exe",
    "vlc.exe",
    "mpv.exe",
    "mpc-hc.exe",
    "mpc-hc64.exe",
    "potplayermini64.exe",
    "potplayer.exe",
    "code.exe",
    "cursor.exe",
    "webstorm64.exe",
    "idea64.exe",
    "pycharm64.exe",
    "clion64.exe",
    "devenv.exe",
    "sublime_text.exe",
    "notepad++.exe",
    "winword.exe",
    "excel.exe",
    "powerpnt.exe",
    "onenote.exe",
    "obsidian.exe",
    "notion.exe",
    "figma.exe",
    "photoshop.exe",
    "illustrator.exe"
  ],

  "masterToggleHotkey": "^!+m",

  "bindings": [
    { "from": "!c",         "to": "^c",            "enabled": true, "desc": "copy" },
    { "from": "!v",         "to": "^v",            "enabled": true, "desc": "paste" },
    { "from": "!+v",        "to": "^+v",           "enabled": true, "desc": "paste and match style" },
    { "from": "!x",         "to": "^x",            "enabled": true, "desc": "cut" },
    { "from": "!a",         "to": "^a",            "enabled": true, "desc": "select all" },
    { "from": "!z",         "to": "^z",            "enabled": true, "desc": "undo" },
    { "from": "!+z",        "to": "^y",            "enabled": true, "desc": "redo" },
    { "from": "!s",         "to": "^s",            "enabled": true, "desc": "save" },
    { "from": "!+s",        "to": "^+s",           "enabled": true, "desc": "save as" },
    { "from": "!w",         "to": "^w",            "enabled": true, "desc": "close tab/window" },
    { "from": "!q",         "to": "!{F4}",         "enabled": true, "desc": "quit app" },
    { "from": "!t",         "to": "^t",            "enabled": true, "desc": "new tab" },
    { "from": "!+t",        "to": "^+t",           "enabled": true, "desc": "reopen closed tab" },
    { "from": "!n",         "to": "^n",            "enabled": true, "desc": "new" },
    { "from": "!+n",        "to": "^+n",           "enabled": true, "desc": "new private/incognito" },
    { "from": "!o",         "to": "^o",            "enabled": true, "desc": "open" },
    { "from": "!p",         "to": "^p",            "enabled": true, "desc": "print" },
    { "from": "!r",         "to": "^r",            "enabled": true, "desc": "reload" },
    { "from": "!f",         "to": "^f",            "enabled": true, "desc": "find" },
    { "from": "!g",         "to": "^g",            "enabled": true, "desc": "find next" },
    { "from": "!+g",        "to": "^+g",           "enabled": true, "desc": "find previous" },
    { "from": "!b",         "to": "^b",            "enabled": true, "desc": "bold" },
    { "from": "!i",         "to": "^i",            "enabled": true, "desc": "italic" },
    { "from": "!u",         "to": "^u",            "enabled": true, "desc": "underline" },
    { "from": "!k",         "to": "^k",            "enabled": true, "desc": "insert link" },
    { "from": "!l",         "to": "^l",            "enabled": true, "desc": "focus address bar" },
    { "from": "!+]",        "to": "^{Tab}",        "enabled": true, "desc": "next tab" },
    { "from": "!+[",        "to": "^+{Tab}",       "enabled": true, "desc": "previous tab" },
    { "from": "!+3",        "to": "{PrintScreen}", "enabled": true, "desc": "screenshot fullscreen" },
    { "from": "!+4",        "to": "#+s",           "enabled": true, "desc": "screenshot region" },
    { "from": "!+2",        "to": "#+s",           "enabled": true, "desc": "screenshot region (alt)" },
    { "from": "!+5",        "to": "#!r",           "enabled": true, "desc": "screen recording (game bar)" },
    { "from": "!Space",     "to": "#s",            "enabled": true, "desc": "spotlight-like search" },
    { "from": "!Left",      "to": "{Home}",        "enabled": true, "desc": "beginning of line" },
    { "from": "!Right",     "to": "{End}",         "enabled": true, "desc": "end of line" },
    { "from": "!+Left",     "to": "+{Home}",       "enabled": true, "desc": "select to beginning of line" },
    { "from": "!+Right",    "to": "+{End}",        "enabled": true, "desc": "select to end of line" },
    { "from": "!Up",        "to": "^{Home}",       "enabled": true, "desc": "top of document" },
    { "from": "!Down",      "to": "^{End}",        "enabled": true, "desc": "bottom of document" },
    { "from": "!+Up",       "to": "^+{Home}",      "enabled": true, "desc": "select to top" },
    { "from": "!+Down",     "to": "^+{End}",       "enabled": true, "desc": "select to bottom" },
    { "from": "!BackSpace", "to": "^{BackSpace}",  "enabled": true, "desc": "delete previous word" },
    { "from": "#Left",      "to": "^{Left}",       "enabled": true, "desc": "word left (Option+Left)" },
    { "from": "#Right",     "to": "^{Right}",      "enabled": true, "desc": "word right (Option+Right)" },
    { "from": "#+Left",     "to": "^+{Left}",      "enabled": true, "desc": "select word left" },
    { "from": "#+Right",    "to": "^+{Right}",     "enabled": true, "desc": "select word right" },
    { "from": "#BackSpace", "to": "^{BackSpace}",  "enabled": true, "desc": "delete word backward" }
  ]
}
